#!/usr/bin/env bash
set -euo pipefail

theme="${1:-auto}"
script_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
if [[ -f "$script_root/config/wezterm/wezterm.lua" ]]; then
    repo_dir="$script_root"
elif [[ -f "$HOME/Projects/terminal-config/config/wezterm/wezterm.lua" ]]; then
    repo_dir="$HOME/Projects/terminal-config"
else
    echo "terminal-theme: cannot find terminal-config checkout" >&2
    exit 1
fi
home_dir="$HOME"

usage() {
    cat <<'EOF'
Usage: terminal-theme [light|night|sunset|auto]

  light    Gruvbox Light    — readable daytime          (07:00–17:59)
  sunset   Gruvbox Dark     — warm amber evening        (18:00–20:59)
  night    Catppuccin Mocha — low-glare dark sessions   (21:00–06:59)
  auto     Pick theme by current time (same windows as above)

Applies consistently across WezTerm colors, Zellij theme, and Codex TUI.
EOF
}

pick_auto() {
    local hour
    hour=$(date +%H)
    if   [[ "$hour" -ge 7  && "$hour" -le 17 ]]; then echo light
    elif [[ "$hour" -ge 18 && "$hour" -le 20 ]]; then echo sunset
    else echo night
    fi
}

copy_base_files() {
    mkdir -p "$home_dir/.config/wezterm" "$home_dir/.config/zellij/layouts" "$home_dir/.codex/themes" "$home_dir/bin"
    cp "$repo_dir/config/wezterm/wezterm.lua"        "$home_dir/.config/wezterm/wezterm.lua"
    cp "$repo_dir/config/zellij/config.kdl"          "$home_dir/.config/zellij/config.kdl"
    cp "$repo_dir/config/zellij/layouts/ai.kdl"      "$home_dir/.config/zellij/layouts/ai.kdl"
    cp "$repo_dir/config/zellij/layouts/codex.kdl"   "$home_dir/.config/zellij/layouts/codex.kdl"
    cp "$repo_dir/config/zellij/layouts/claude.kdl"  "$home_dir/.config/zellij/layouts/claude.kdl"
    cp "$repo_dir/config/zellij/layouts/help.kdl"    "$home_dir/.config/zellij/layouts/help.kdl"
    cp "$repo_dir/config/zellij/layouts/llm.kdl"     "$home_dir/.config/zellij/layouts/llm.kdl"
    cp "$repo_dir/config/zellij/layouts/main.kdl"    "$home_dir/.config/zellij/layouts/main.kdl"
    cp "$repo_dir/config/zellij/layouts/sec.kdl"     "$home_dir/.config/zellij/layouts/sec.kdl"
    cp "$repo_dir/config/codex/themes/gruvbox-light-darker.tmTheme" "$home_dir/.codex/themes/gruvbox-light-darker.tmTheme"
    cp -p "$repo_dir/bin/terminal-ai"                "$home_dir/bin/terminal-ai"
    cp -p "$repo_dir/bin/terminal-help"              "$home_dir/bin/terminal-help"
    chmod +x "$home_dir/bin/terminal-ai" "$home_dir/bin/terminal-help"
}

patch_wezterm_colors() {
    python3 - "$home_dir/.config/wezterm/wezterm.lua" "$1" <<'PYEOF'
import sys, re

path  = sys.argv[1]
theme = sys.argv[2]

COLORS = {
    'light': """\
  colors = {
    foreground = '#3c3836',
    background = '#f2e5bc',
    cursor_bg = '#3c3836',
    cursor_fg = '#f2e5bc',
    cursor_border = '#3c3836',
    selection_fg = '#1d2021',
    selection_bg = '#fabd2f',
    scrollbar_thumb = '#d5c4a1',
    split = '#d5c4a1',
    ansi = { '#f2e5bc', '#cc241d', '#4e9a06', '#7a5c00', '#004f6b', '#9d4f74', '#4f8a66', '#5f534a' },
    brights = { '#3c3836', '#fb4934', '#8ec07c', '#b38600', '#2f7a8a', '#d3869b', '#83a598', '#ffffff' },
  },""",
    'night': """\
  colors = {
    foreground = '#cdd6f4',
    background = '#1e1e2e',
    cursor_bg = '#f5e0dc',
    cursor_fg = '#1e1e2e',
    cursor_border = '#f5e0dc',
    selection_fg = '#11111b',
    selection_bg = '#f9e2af',
    scrollbar_thumb = '#45475a',
    split = '#45475a',
    ansi = { '#45475a', '#f38ba8', '#a6e3a1', '#f9e2af', '#89b4fa', '#f5c2e7', '#94e2d5', '#bac2de' },
    brights = { '#585b70', '#f38ba8', '#a6e3a1', '#f9e2af', '#89b4fa', '#f5c2e7', '#94e2d5', '#a6adc8' },
  },""",
    'sunset': """\
  colors = {
    foreground = '#ffecd2',
    background = '#1e1428',
    cursor_bg = '#ff9a3c',
    cursor_fg = '#1e1428',
    cursor_border = '#ff9a3c',
    selection_fg = '#1e1428',
    selection_bg = '#ff9a3c',
    scrollbar_thumb = '#3d2b5e',
    split = '#ff9a3c',
    ansi = { '#1e1428', '#ff4d6d', '#80ffdb', '#ffd166', '#48cae4', '#c77dff', '#ff9a3c', '#ffecd2' },
    brights = { '#3d2b5e', '#ff6b9d', '#a0ffd6', '#ffe699', '#72d9f5', '#d9a0ff', '#ffb86c', '#ffffff' },
  },""",
}

text = open(path).read()
text = re.sub(r'  colors = \{.*?  \},', COLORS[theme], text, flags=re.DOTALL)
open(path, 'w').write(text)
PYEOF
}

patch_zellij_theme() {
    python3 - "$home_dir/.config/zellij/config.kdl" "$1" <<'PYEOF'
import sys, re

path       = sys.argv[1]
theme_name = sys.argv[2]

THEME_BLOCKS = {
    'ai_catppuccin_mocha': """\
themes {
    ai_catppuccin_mocha {
        bg 30 30 46
        fg 205 214 244
        black 69 71 90
        red 243 139 168
        green 166 227 161
        yellow 249 226 175
        blue 137 180 250
        magenta 245 194 231
        orange 250 179 135
        cyan 148 226 213
        white 166 173 200
    }
}""",
    'ai_gruvbox_warm': """\
themes {
    ai_gruvbox_warm {
        bg 40 40 40
        fg 235 219 178
        black 40 40 40
        red 204 36 29
        green 152 151 26
        yellow 215 153 33
        blue 69 133 136
        magenta 177 98 134
        orange 254 128 25
        cyan 104 157 106
        white 235 219 178
    }
}""",
    'ai_gruvbox_day': """\
themes {
    ai_gruvbox_day {
        bg 251 241 199
        fg 60 56 54
        black 251 241 199
        red 204 36 29
        green 152 151 26
        yellow 215 153 33
        blue 69 133 136
        magenta 177 98 134
        orange 175 58 3
        cyan 0 107 139
        white 60 56 54
    }
}""",
    'sunset': """\
themes {
    sunset {
        fg      255 236 210
        bg      30 20 40
        black   30 20 40
        red     255 77 109
        green   128 255 219
        yellow  255 209 102
        blue    72 202 228
        magenta 199 125 255
        orange  255 154 60
        cyan    255 154 60
        white   255 236 210

        text_selected {
            base        30 20 40
            background  255 154 60
            emphasis_0  30 20 40
            emphasis_1  61 43 94
            emphasis_2  30 20 40
            emphasis_3  61 43 94
        }

        table_cell_selected {
            base        30 20 40
            background  255 154 60
            emphasis_0  30 20 40
            emphasis_1  61 43 94
            emphasis_2  30 20 40
            emphasis_3  61 43 94
        }

        list_selected {
            base        30 20 40
            background  255 154 60
            emphasis_0  30 20 40
            emphasis_1  61 43 94
            emphasis_2  30 20 40
            emphasis_3  61 43 94
        }
    }
}""",
}

text = open(path).read()

# Replace theme reference line
text = re.sub(r'theme "[^"]*"', f'theme "{theme_name}"', text)

# Replace themes { ... } block using brace counting
start = text.index('themes {')
depth = 0
end = start
for i, c in enumerate(text[start:]):
    if c == '{':
        depth += 1
    elif c == '}':
        depth -= 1
        if depth == 0:
            end = start + i + 1
            break

text = text[:start] + THEME_BLOCKS[theme_name] + text[end:]
open(path, 'w').write(text)
PYEOF
}

set_codex_theme() {
    local codex_theme="$1"
    local codex_config="$home_dir/.codex/config.toml"
    mkdir -p "$(dirname "$codex_config")"
    python3 - "$codex_config" "$codex_theme" <<'PYEOF'
import sys
from pathlib import Path

path  = Path(sys.argv[1])
theme = sys.argv[2]
text  = path.read_text() if path.exists() else ""
entry = f'theme = "{theme}"'

if "[tui]" not in text:
    text = text.rstrip() + "\n\n[tui]\n" + entry + "\n"
else:
    start = text.index("[tui]")
    next_section = text.find("\n[", start + 1)
    end = len(text) if next_section == -1 else next_section
    block = text[start:end]
    rest  = "" if next_section == -1 else text[next_section:]
    lines = block.splitlines()
    for i, line in enumerate(lines):
        if line.strip().startswith("theme"):
            lines[i] = entry
            break
    else:
        lines.insert(1, entry)
    text = text[:start] + "\n".join(lines) + rest

path.write_text(text)
PYEOF
}

apply_light() {
    copy_base_files
    patch_wezterm_colors light
    patch_zellij_theme ai_gruvbox_day
    set_codex_theme gruvbox-light-darker
    echo "Applied: light (Gruvbox Light Darker)"
}

apply_night() {
    copy_base_files
    patch_wezterm_colors night
    patch_zellij_theme ai_catppuccin_mocha
    set_codex_theme gruvbox-dark
    echo "Applied: night (Catppuccin Mocha)"
}

apply_sunset() {
    copy_base_files
    patch_wezterm_colors sunset
    patch_zellij_theme sunset
    set_codex_theme gruvbox-dark
    echo "Applied: sunset"
}

case "$theme" in
    light|day|gruvbox-light)
        apply_light ;;
    night|dark|catppuccin|mocha)
        apply_night ;;
    sunset|warm|gruvbox-dark|gruvbox-warm)
        apply_sunset ;;
    auto)
        selected=$(pick_auto)
        echo "auto → $selected (hour=$(date +%H))"
        apply_"$selected"
        ;;
    -h|--help|help)
        usage ;;
    *)
        echo "terminal-theme: unsupported template: $theme" >&2
        usage >&2
        exit 2 ;;
esac
