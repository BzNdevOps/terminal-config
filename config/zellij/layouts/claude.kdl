layout {
    pane split_direction="vertical" size="70%" {
        pane command="bash" {
            args "-lc" "/home/bz/.local/bin/claude || true; exec bash -li"
        }
        pane split_direction="horizontal" {
            pane command="bash" {
                args "-lc" "ssh -t bzserv '~/Projects/tmux-agent-human-tests/scripts/watch-auto.sh' || exec bash -li"
            }
            pane
        }
    }
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
}
