layout cwd="/home/bz" {
    pane name="shortcuts" command="bash" {
        args "-lc" "clear; cat <<'EOF'\nAI terminal shortcuts\n\nZellij navigation\n  Alt+h / Alt+l        focus left / right pane\n  Alt+j / Alt+k        focus down / up pane\n  Ctrl+g Ctrl+t 1      go to codex tab\n  Ctrl+g Ctrl+t 2      go to claude tab\n  Ctrl+g Ctrl+t 3      go to ops tab\n  Ctrl+g Ctrl+t 4      go to llm tab\n  Ctrl+g Ctrl+t 5      go to sec tab\n  Ctrl+g Ctrl+t 6      go to help tab\n\nZellij panes\n  Ctrl+g Ctrl+p f      fullscreen focused pane, repeat to restore\n  Ctrl+g Ctrl+p x      close focused pane\n  Ctrl+g Ctrl+p r      new pane to the right\n  Ctrl+g Ctrl+p d      new pane below\n  Ctrl+g Ctrl+p c      rename focused pane\n\nZellij resize\n  Ctrl+g Ctrl+n        resize mode\n  h / j / k / l        resize focused pane\n  + / -                grow / shrink\n  Esc or Enter         exit resize mode\n\nZellij scroll and search\n  Ctrl+g Ctrl+s        scroll mode\n  j / k                scroll line\n  Ctrl+f / Ctrl+b      page down / page up\n  s                    search in scrollback\n  Ctrl+c               return to bottom\n\nZellij session\n  Ctrl+g Ctrl+o d      detach session, keeps agents running\n  Ctrl+g Ctrl+o w      session manager\n  Ctrl+g Ctrl+o l      layout manager\n\nLLM monitoring\n  /home/bz/bin/bzserv-llm-monitor gpu\n  /home/bz/bin/bzserv-llm-monitor status\n  /home/bz/bin/bzserv-llm-monitor traffic\n  /home/bz/bin/bzserv-llm-monitor webui-logs\n  /home/bz/bin/bzserv-llm-monitor ollama-logs\n\nSecurity monitoring\n  /home/bz/bin/bzserv-security-monitor overview\n  /home/bz/bin/bzserv-security-monitor surface\n  /home/bz/bin/bzserv-security-monitor auth\n  /home/bz/bin/bzserv-security-monitor firewall\n\nClose sessions from shell\n  zellij list-sessions\n  zellij delete-session ai --force\n  zellij delete-session main --force\n  zellij delete-all-sessions --force\n\nWezTerm\n  Ctrl+Shift+F9        open AI cockpit\n  Ctrl+Shift+F10       open Codex-only session\n  Ctrl+Shift+F11       open Claude-only session\n  Ctrl+Shift+F         search terminal output\n  Ctrl+Shift+PageUp    scroll page up\n  Ctrl+Shift+PageDown  scroll page down\n  Alt+Shift+V          paste latest screenshot path\n\nTheme switching\n  terminal-theme light       apply the light day template\n  terminal-theme --help      show available template commands\n  Restart Codex if its input box keeps the old cached colors.\n\nDaily flow\n  1. Use Alt+h/j/k/l to move without mouse.\n  2. Use Ctrl+g Ctrl+p f for full-screen Codex/Claude.\n  3. Use Ctrl+g Ctrl+t 1/2/3/4/5/6 to jump tabs.\n  4. Use Ctrl+g Ctrl+o d before closing WezTerm.\nEOF\nexec bash -li"
    }
    pane size=1 borderless=true {
        plugin location="compact-bar"
    }
}
