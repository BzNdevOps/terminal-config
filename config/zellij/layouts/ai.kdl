layout {
    tab name="Agents" focus=true cwd="/home/bz" {
        pane split_direction="vertical" {
            pane name="claude" command="bash" {
                args "-lc" "cd /home/bz; /home/bz/.local/bin/claude || true; exec bash -li"
            }
            pane name="codex" command="bash" {
                args "-lc" "cd /home/bz; /home/bz/.npm-global/bin/codex -c 'tui.theme=\"gruvbox-light-darker\"' || true; exec bash -li"
            }
        }
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="ops" cwd="/home/bz" {
        pane split_direction="vertical" {
            pane name="shell" command="bash" {
                args "-li"
            }
            pane name="shell" command="bash" {
                args "-li"
            }
        }
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="llm" cwd="/home/bz" {
        pane split_direction="vertical" size="50%" {
            pane split_direction="horizontal" {
                pane name="gpu" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-llm-monitor gpu; exec bash -li"
                }
                pane name="services" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-llm-monitor status; exec bash -li"
                }
            }
            pane split_direction="horizontal" {
                pane name="real traffic PG/TG" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-llm-monitor traffic; exec bash -li"
                }
                pane name="open-webui logs" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-llm-monitor webui-logs; exec bash -li"
                }
            }
        }
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="sec" cwd="/home/bz" {
        pane split_direction="vertical" size="50%" {
            pane split_direction="horizontal" {
                pane name="security/access" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-security-monitor overview; exec bash -li"
                }
                pane name="attack surface" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-security-monitor surface; exec bash -li"
                }
            }
            pane split_direction="horizontal" {
                pane name="ssh/auth events" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-security-monitor auth; exec bash -li"
                }
                pane name="firewall/fail2ban" command="bash" {
                    args "-lc" "/home/bz/bin/bzserv-security-monitor firewall; exec bash -li"
                }
            }
        }
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }

    tab name="help" cwd="/home/bz" {
        pane name="shortcuts" command="bash" {
            args "-lc" "clear; /home/bz/bin/terminal-help; exec bash -li"
        }
        pane size=1 borderless=true {
            plugin location="compact-bar"
        }
    }
}
